{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EstraIME Model Manifest",
  "type": "object",
  "properties": {
    "model_id": { "type": "string" },
    "backend": { "type": "string", "enum": ["llama.cpp"] },
    "download_url": { "type": "string" },
    "sha256": { "type": "string" },
    "size_bytes": { "type": "integer", "minimum": 0 }
  },
  "required": ["model_id", "backend", "download_url", "sha256", "size_bytes"]
}
